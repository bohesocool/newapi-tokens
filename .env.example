# 复制本文件为 .env 并按需修改：cp .env.example .env
# .env 不会被提交到 git（见 .gitignore）

# NewAPI 的 PostgreSQL 连接信息（psycopg 直连，仅只读查询，不会写入 new-api 库）
PG_HOST=postgres
PG_PORT=5432
PG_USER=root
PG_DB=new-api
PG_PASSWORD=改成_new-api_的_POSTGRES_PASSWORD

# 要统计的 token 名称
TOKEN_NAME=ducker

# 首次启动时的初始登录密码（之后可在「设置」页修改；改后此项不再生效）
ADMIN_PASSWORD=admin
